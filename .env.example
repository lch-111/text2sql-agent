# Text-to-SQL Agent 环境变量配置（示例）
# 云端 API 模式（OpenAI 兼容），无需本地 GPU

# ---- API 连接 ----
# 支持任意 OpenAI 兼容 API：阿里云 DashScope、DeepSeek、智谱、OpenAI 官方等
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- 管理令牌（SHA256 哈希值，留空仅允许本地访问管理接口）----
# 生成: echo -n 'your-token' | sha256sum
ADMIN_TOKEN=

# ---- 四个专用模型 ----
ROUTER_MODEL=glm-4-flash          # 分类/路由用（轻量免费模型）
GENERATOR_MODEL=deepseek-v4-flash # SQL 生成用（需较强推理能力）
CRITIC_MODEL=glm-4-flash          # 校验用（轻量免费模型）
RERANKER_MODEL=glm-4-flash        # Schema 精排用（轻量模型）

# ---- 数据库配置（单数据源）----
DB_TYPE=mysql
# DB_TYPE=sqlite
# DB_TYPE=postgres

# MySQL 配置
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=my_db
MYSQL_USER=root
MYSQL_PASSWORD=123456

# SQLite 配置（DB_TYPE=sqlite 时使用）
DB_PATH=data/retail_warehouse.db

# PostgreSQL 配置（DB_TYPE=postgres 时使用）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=text2sql
PG_USER=text2sql
PG_PASSWORD=text2sql_secret

# ---- Redis 缓存 ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_SIMILARITY_THRESHOLD=0.9
CACHE_TTL_SECONDS=3600

# ---- Agent 配置 ----
ENABLE_SQL_OPTIMIZER=true
MAX_RETRIES=2

# ---- 日志 ----
LOG_LEVEL=INFO
DEBUG=true
